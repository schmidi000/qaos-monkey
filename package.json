{
  "name": "qaosmonkey",
  "version": "0.1.1",
  "description": "Tech-agnostic agentic mobile exploratory testing CLI.",
  "type": "module",
  "bin": {
    "qaosmonkey": "dist/cli.js"
  },
  "types": "./dist/types.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "qaosmonkey": "node --experimental-transform-types src/cli.ts",
    "test": "node --experimental-transform-types --test test/*.test.ts"
  },
  "files": [
    "dist",
    "qaos-monkey.config.example.ts",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://qaosmonkey.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schmidi000/qaos-monkey.git"
  },
  "bugs": {
    "url": "https://github.com/schmidi000/qaos-monkey/issues"
  },
  "engines": {
    "node": ">=22.6"
  },
  "keywords": [
    "mobile",
    "testing",
    "llm",
    "agent",
    "exploratory-testing"
  ],
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "license": "MIT-0",
  "publishConfig": {
    "access": "public"
  },
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "dependencies": {
    "undici-types": "^7.24.6"
  },
  "author": ""
}
